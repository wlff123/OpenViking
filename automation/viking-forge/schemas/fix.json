{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["summary", "tests", "risks"],
  "properties": {
    "summary": {"type": "string", "minLength": 1, "maxLength": 1200},
    "tests": {
      "type": "array",
      "items": {"type": "string", "maxLength": 300},
      "maxItems": 20
    },
    "risks": {
      "type": "array",
      "items": {"type": "string", "maxLength": 300},
      "maxItems": 20
    }
  },
  "additionalProperties": false
}

